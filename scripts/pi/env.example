# Rendezvous IL kiosk environment
# Installed to ~/.config/rendezvous-kiosk/env by install-kiosk.sh (first run only).
# Edit that file, then: systemctl --user daemon-reload && systemctl --user restart rendezvous-kiosk.service

# X11 display for Chromium on Pi OS Desktop (usually :0; XWayland on Bookworm Wayland).
DISPLAY=:0

# Optional: pin one panel (disables auto-rotate). Values: schedule, weather, meal, map, wifi, upcoming, volunteers, announcements, all
# VIEW=meal

# Optional: fleet device id for heartbeat (appended as ?device=…). Example: rendezvous-lu-01
# DEVICE_ID=rendezvous-lu-01

# Optional: point at a local/dev Next.js server instead of production.
# Quote the URL — unquoted & breaks when this file is sourced by bash.
# LOCAL_URL="http://192.168.1.10:3000/live-updates?sync=1&kiosk=1"

# Optional: full kiosk URL override (takes precedence over LOCAL_URL and production default).
# KIOSK_URL="https://rendezvousil.com/live-updates?sync=1&kiosk=1&view=meal"

# Fleet device id for heartbeat (Pi-2). install-kiosk.sh sets this on first install if missing.
# DEVICE_ID=rendezvous-lu-01
