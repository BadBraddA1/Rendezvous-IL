# Xcode Cloud build gate for Rendezvous IL
#
# Flip this when you want Cloud to archive / ship TestFlight again:
#   XCODE_CLOUD_BUILDS_ENABLED=1
#
# Keep it at 0 while iterating on main so every push doesn’t burn a Cloud build.
# One-off skip without editing this file: put [ci skip] in the commit message.
#
# Read by ios/ci_scripts/ci_post_clone.sh (nonzero exit aborts the Cloud run early).

XCODE_CLOUD_BUILDS_ENABLED=0
